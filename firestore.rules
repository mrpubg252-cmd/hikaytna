rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Live chats matches
    match /chats/{seriesId}/messages/{messageId} {
      allow read: if true;
      allow create: if request.resource.data.text is string 
                   && request.resource.data.text.size() > 0 
                   && request.resource.data.text.size() <= 500
                   && request.resource.data.username is string
                   && request.resource.data.username.size() > 0
                   && request.resource.data.username.size() <= 100;
    }

    // Reports matches
    match /reports/{reportId} {
      // Strict privacy block: reports are write-only for guest users to prevent data scraping or leakage
      allow read: if false;
      allow create: if request.resource.data.reason is string 
                   && request.resource.data.reason.size() > 0
                   && request.resource.data.comment is string
                   && request.resource.data.comment.size() > 0
                   && request.resource.data.comment.size() <= 5000;
    }
  }
}
