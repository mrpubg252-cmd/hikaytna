    "axios": "^1.16.1",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.3.0",
    "firebase": "^12.13.0",
    "form-data": "^4.0.6",
    "hls.js": "^1.6.16",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "openai": "^6.38.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.15.1",
