{
  "entities": {
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A live chat message sent by a user for a specific series",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The text content of the message"
        },
        "username": {
          "type": "string",
          "description": "The user's customizable handle"
        },
        "avatarColor": {
          "type": "string",
          "description": "Tailwind color class for avatar styling"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The server-generated timestamp"
        }
      },
      "required": ["text", "username", "avatarColor", "createdAt"]
    },
    "Report": {
      "title": "Report",
      "description": "A quality/technical issue report filed by a user for a video stream",
      "type": "object",
      "properties": {
        "seriesTitle": {
          "type": "string",
          "description": "Title of the series"
        },
        "episodeTitle": {
          "type": "string",
          "description": "Title of the episode"
        },
        "episodeSlug": {
          "type": "string",
          "description": "URL slug of the episode"
        },
        "reason": {
          "type": "string",
          "description": "The selected category/reason for reporting"
        },
        "comment": {
          "type": "string",
          "description": "Detailed explanation of the issue"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The server-generated timestamp"
        },
        "userAgent": {
          "type": "string",
          "description": "Device and browser info of reporter"
        },
        "timestamp": {
          "type": "string",
          "description": "ISO timestamp format"
        }
      },
      "required": ["reason", "comment", "createdAt"]
    }
  },
  "firestore": {
    "/chats/{seriesId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Subcollection containing messages for a series chatroom"
    },
    "/reports/{reportId}": {
      "schema": { "$ref": "#/entities/Report" },
      "description": "Global collection containing all submitted stream issue reports"
    }
  }
}
